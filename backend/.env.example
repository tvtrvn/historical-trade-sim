# ── Database ────────────────────────────────────────────────────────────────
# Local SQLite (fastest path to "it works on my machine")
DATABASE_URL=sqlite+aiosqlite:///./local.db
# Production (Neon / Koyeb-managed Postgres)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# ── CORS ────────────────────────────────────────────────────────────────────
# Frontend origins allowed to call the API (comma-separated). NEVER use "*".
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Environment ─────────────────────────────────────────────────────────────
# "production" disables /docs, enables HSTS, and tightens logs.
ENV=development

# ── Abuse protection (in-memory, per IP) ────────────────────────────────────
# Global: every request burns budget here.
RATE_LIMIT_PER_MINUTE=120
# Heavy endpoints (/simulate + scenario mutations) burn an additional, tighter
# bucket on top of the global one.
HEAVY_RATE_LIMIT_PER_MINUTE=20
# Hard cap on request body size in bytes. The API never needs large payloads.
MAX_BODY_BYTES=65536
# Per-client cap on saved scenarios (anti-spam).
MAX_SCENARIOS_PER_CLIENT=100
# Honor X-Forwarded-For for client-IP detection. ONLY set true when behind a
# trusted proxy/CDN that strips & rewrites this header.
TRUST_PROXY=false

# ── Storage TTL (daily cleanup) ─────────────────────────────────────────────
# scenario_results rows older than this are deleted by the cleanup job. The
# saved scenarios themselves are NEVER deleted — the user can re-run them at
# any time to regenerate fresh metrics.
RESULT_RETENTION_DAYS=30
# Shared bearer token that authorizes POST /api/v1/maintenance/cleanup AND
# POST /api/v1/maintenance/refresh-prices.
# Generate once with: openssl rand -hex 32
# Empty string (the default) DISABLES both endpoints entirely — perfect for
# local dev. Set this in Koyeb + as a GitHub secret to enable the daily cron.
MAINTENANCE_TOKEN=

# ── Market-data provider (real prices) ──────────────────────────────────────
# Free Tiingo API key — get one at https://www.tiingo.com/account/api/token
# (free signup, no credit card). When set, the fetcher tries Tiingo first
# for split/dividend-adjusted closes. When empty, the fetcher uses Stooq
# (also free, no key) and falls back to a deterministic synthetic GBM if
# Stooq is unreachable. Leaving this empty is a fine choice for portfolio
# demos that don't need pixel-perfect prices.
TIINGO_API_KEY=
# Set to "true" once to wipe + repopulate all historical_prices on the next
# seed run (used when upgrading from synthetic to real data). Reset to
# "false" afterwards — refresh is incremental in steady state.
MARKETDATA_FORCE_REFRESH=false
# Earliest date the fetcher requests from a provider. The curated SECURITIES
# list assumes 2010+ data; older dates may return empty for some tickers.
MARKETDATA_HISTORY_START=2010-01-01
